{
	"name": "react-native-tiktok-business-kit",
	"version": "0.1.0",
	"description": "A React Native wrapper for TikTok Business SDK. Easily track events, manage user identifiers, handle attribution, and integrate TikTok marketing analytics in your React Native applications with a unified TypeScript API.",
	"main": "./lib/module/index.js",
	"react-native": "./src/index.ts",
	"types": "./lib/typescript/src/index.d.ts",
	"exports": {
		".": {
			"react-native": "./src/index.ts",
			"source": "./src/index.ts",
			"types": "./lib/typescript/src/index.d.ts",
			"default": "./lib/module/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"README.md",
		"README.tr.md",
		"src",
		"lib",
		"android",
		"ios",
		"cpp",
		"nitrogen",
		"nitro.json",
		"*.podspec",
		"react-native.config.js",
		"!ios/build",
		"!android/build",
		"!android/gradle",
		"!android/gradlew",
		"!android/gradlew.bat",
		"!android/local.properties",
		"!**/__tests__",
		"!**/__fixtures__",
		"!**/__mocks__",
		"!**/.*"
	],
	"scripts": {
		"example": "yarn workspace react-native-tiktok-business-kit-example",
		"clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
		"prepare": "bob build",
		"nitrogen": "nitrogen",
		"typecheck": "tsc",
		"lint": "eslint \"**/*.{js,ts,tsx}\"",
		"test": "jest",
		"release": "release-it --only-version",
		"web": "vite",
		"build:web": "vite build"
	},
	"keywords": [
		"react-native",
		"ios",
		"android"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/oguzhankelees/react-native-tiktok-business-kit.git"
	},
	"author": "Oğuzhan Keleş <oguzhankelees@gmail.com> (https://github.com/oguzhankelees)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/oguzhankelees/react-native-tiktok-business-kit/issues"
	},
	"homepage": "https://github.com/oguzhankelees/react-native-tiktok-business-kit#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"devDependencies": {
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/compat": "^2.0.3",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@jest/globals": "^30.0.0",
		"@react-native/babel-preset": "0.85.0",
		"@react-native/eslint-config": "0.85.0",
		"@react-native/jest-preset": "0.85.0",
		"@release-it/conventional-changelog": "^10.0.6",
		"@types/react": "^19.2.0",
		"commitlint": "^20.5.0",
		"del-cli": "^7.0.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-ft-flow": "^3.0.11",
		"eslint-plugin-prettier": "^5.5.5",
		"jest": "^30.3.0",
		"lefthook": "^2.1.4",
		"nitrogen": "^0.35.9",
		"prettier": "^3.8.3",
		"react": "19.2.3",
		"react-native": "0.85.0",
		"react-native-builder-bob": "^0.41.0",
		"react-native-nitro-modules": "^0.35.9",
		"react-native-web": "~0.21.1",
		"release-it": "^19.2.4",
		"turbo": "^2.8.21",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"react": "*",
		"react-native": "*",
		"react-native-nitro-modules": "^0.35.9"
	},
	"workspaces": [
		"example"
	],
	"packageManager": "yarn@4.11.0",
	"react-native-builder-bob": {
		"source": "src",
		"output": "lib",
		"targets": [
			[
				"custom",
				{
					"script": "nitrogen",
					"clean": "nitrogen/"
				}
			],
			[
				"module",
				{
					"esm": true
				}
			],
			[
				"typescript",
				{
					"project": "tsconfig.build.json"
				}
			]
		]
	},
	"jest": {
		"preset": "@react-native/jest-preset",
		"modulePathIgnorePatterns": [
			"<rootDir>/example/node_modules",
			"<rootDir>/lib/"
		]
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"release-it": {
		"git": {
			"commitMessage": "chore: release ${version}",
			"tagName": "v${version}"
		},
		"npm": {
			"publish": true
		},
		"github": {
			"release": true
		},
		"plugins": {
			"@release-it/conventional-changelog": {
				"preset": {
					"name": "angular"
				}
			}
		}
	},
	"create-react-native-library": {
		"type": "nitro-module",
		"languages": "kotlin-swift",
		"tools": [
			"eslint",
			"jest",
			"lefthook",
			"release-it",
			"vite"
		],
		"version": "0.62.0"
	}
}
